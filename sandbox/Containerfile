# Per-user sandbox image (mvp.md §8).
#
# Contents:
#   - Node 22 (slim) for the SvelteKit dev server
#   - git + ca-certificates + curl (template clone / health checks)
#   - nous binary (CGO-disabled; built externally and copied)
#   - YOLO nous config (env-var-resolved at daemon startup)
#   - entrypoint that starts vite in background + nous daemon in foreground
#
# Build via ../sandbox/build.sh which sets NOUS_REV.

FROM node:22-bookworm-slim

ARG NOUS_REV=unknown
LABEL org.opencontainers.image.revision="${NOUS_REV}"
LABEL org.opencontainers.image.source="https://github.com/skipper/homa"
LABEL org.opencontainers.image.title="homa-sandbox"

RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates curl \
 && rm -rf /var/lib/apt/lists/*

# /root/.claude is the bind-mount target for the host's Claude Code
# credentials file (mounted read-only by the orchestrator when configured).
# Created here so the mount has a parent dir even on fresh containers.
RUN mkdir -p /root/.claude

# code-server v4.96.2 (pinned for reproducibility). Tarball install rather
# than apt repo so the image build is offline-deterministic once cached.
# Symlinked into /usr/local/bin so the entrypoint just calls `code-server`.
# /root/.local/share/code-server is the user-data dir; the orchestrator
# bind-mounts a per-user podman volume there so settings/extensions
# survive container respawn.
ARG CODE_SERVER_VERSION=4.96.2
RUN curl -fsSL "https://github.com/coder/code-server/releases/download/v${CODE_SERVER_VERSION}/code-server-${CODE_SERVER_VERSION}-linux-amd64.tar.gz" \
    | tar -xz -C /opt \
 && ln -s "/opt/code-server-${CODE_SERVER_VERSION}-linux-amd64/bin/code-server" /usr/local/bin/code-server \
 && mkdir -p /root/.local/share/code-server

COPY nous /usr/local/bin/nous
# nous looks for config.json at nousDir (= dir of the binary) or cwd; placing
# it next to the binary lets every sandbox launch find it without writing
# into the user's worktree. /etc/homa keeps a reference copy for grep-ability.
COPY nous.config.json /usr/local/bin/config.json
COPY nous.config.json /etc/homa/nous.config.json
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh /usr/local/bin/nous

WORKDIR /workspace
EXPOSE 9000 5173 8443
ENTRYPOINT ["/entrypoint.sh"]
